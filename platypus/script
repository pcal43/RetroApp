#!/bin/zsh

# platypus copies this file into Resources and names it 'script'

/usr/bin/osascript -e "display alert \"FOO\" message \"BAR\""

 
show_error() {
  local text="${1:-An unknown error occurred.}"

  /usr/bin/osascript <<EOF
display dialog ${text@Q} ¬
  with title "RetroApp Error" ¬
  buttons {"OK"} ¬
  default button "OK" ¬
  with icon stop
EOF
}

/usr/bin/osascript -e "display alert \"FOO\" message \"BAR\""

print "OK!" > "$HOME/raoutput.txt"

RESOURCES_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

print "command: $RESOURCES_DIR/cli/retroapp drag" >> "$HOME/raoutput.txt"
print "args: $@" >> "$HOME/raoutput.txt"
print "" >> "$HOME/raoutput.txt"

output=$(/bin/zsh -l "$RESOURCES_DIR/cli/retroapp" drag "$@" 2>&1)
exit_code=$?

print "$output" >> "$HOME/raoutput.txt"

if [[ $exit_code -ne 0 ]]; then
  show_error "$output"
  exit $exit_code
fi
