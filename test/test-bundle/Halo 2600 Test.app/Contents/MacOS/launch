#!/bin/sh
set -x
BUNDLE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)/../.."

# HOME is sandboxed so the emulator stores its config per-game under RetroApp/
HOME_SANDBOX_DIR="$HOME/Library/Application Support/RetroApp/Stella/Halo 2600 Test"

# The subdir where the emulator will read/write its config.
EMU_SANDBOX_DIR="$HOME_SANDBOX_DIR/Library/Application Support/Stella"

ROM_PATH="${BUNDLE_DIR}/Contents/Resources/Roms/Halo2600.a26"

# Search for the emulator; EMU_APP_SEARCH_PATH is colon-separated.
_EMU_SEARCH="${BUNDLE_DIR}/Stella.app:/Applications/Stella.app"
EMU_PATH=""
_old_IFS="$IFS"; IFS=:
for _EMU_CANDIDATE in $_EMU_SEARCH; do
  IFS="$_old_IFS"
  if [ -e "$_EMU_CANDIDATE" ]; then
    EMU_PATH="$_EMU_CANDIDATE"
    break
  fi
done
IFS="$_old_IFS"
if [ -z "$EMU_PATH" ]; then
  echo "Error: could not find emulator" >&2
  exit 1
fi

if ! [ -d "$EMU_SANDBOX_DIR" ]; then
  # First launch: seed the sandboxed config dir from the bundled Config/.
  set +e
  mkdir -p "${EMU_SANDBOX_DIR}"
  cp -c -r "${BUNDLE_DIR}/Contents/Resources/Config/"* "${EMU_SANDBOX_DIR}"
  set -e
fi

# Launch: use 'open' for .app bundles, direct exec for plain binaries.
case "$EMU_PATH" in
  *.app)
    HOME="${HOME_SANDBOX_DIR}" open "${EMU_PATH}" --args -fullscreen 1 "${ROM_PATH}"
    ;;
  *)
    HOME="${HOME_SANDBOX_DIR}" "${EMU_PATH}" -fullscreen 1 "${ROM_PATH}"
    ;;
esac
