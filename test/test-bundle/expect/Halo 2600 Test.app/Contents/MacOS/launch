#!/bin/sh
set -x
RUN_BUNDLE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)/../.."

# HOME is sandboxed so the emulator stores its config per-game under RetroApp/
RUN_HOME_SANDBOX_DIR="$HOME/Library/Application Support/RetroApp/stella/Halo 2600 Test"

# The subdir where the emulator will read/write its config.
RUN_SANDBOXED_CONFIG_DIR="$RUN_HOME_SANDBOX_DIR/Library/Application Support/Stella"

RUN_ROM_PATH="${RUN_BUNDLE_DIR}/Contents/Resources/Roms/Halo2600.a26"


# Find the emulator: prefer a bundled .app in Contents/Resources/Emulator/,
# then fall back to EMU_APP_PATH.
RUN_EMU_BUNDLED="${RUN_BUNDLE_DIR}/Contents/Resources/Emulator/"*.app
if [ -e "$RUN_EMU_BUNDLED" ]; then
  RUN_EMU_PATH="$RUN_EMU_BUNDLED"
elif [ -e "/Applications/Stella.app" ]; then
  RUN_EMU_PATH="/Applications/Stella.app"
else
  echo "Error: could not find emulator" >&2
  exit 1
fi

if ! [ -d "$RUN_SANDBOXED_CONFIG_DIR" ]; then
  # First launch: deploy bundled config into the per-game sandbox.
  set +e
  mkdir -p "${RUN_SANDBOXED_CONFIG_DIR}"
  cp -r "$RUN_BUNDLE_DIR/Contents/Resources/Config/." "$RUN_SANDBOXED_CONFIG_DIR/"
  set -e
fi

# Launch the emulator.
HOME="${RUN_HOME_SANDBOX_DIR}" open "${RUN_EMU_PATH}" --args -fullscreen 1 "${RUN_ROM_PATH}"
